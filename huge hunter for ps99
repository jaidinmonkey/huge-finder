local function getClosestPlayer()
    local target = nil
    local dist = math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local currentDist = (player.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if currentDist < dist then
                dist = currentDist
                target = p
            end
        end
    end
    return target
end

local function applyESPToCharacter(p, char)
    if not p or p == player or not char then return end
    task.wait(0.5)
    
    local head = char:WaitForChild("Head", 5)
    if not head then return end
    
    local uniqueKey = p.Name .. "_esp"
    if espObjects[uniqueKey] then espObjects[uniqueKey]:Destroy() espObjects[uniqueKey] = nil end

    local container = Instance.new("Folder")
    container.Name = uniqueKey
    container.Parent = gui
    espObjects[uniqueKey] = container

    if espActive then
        local highlight = Instance.new("Highlight")
        highlight.FillTransparency = 0.5
        highlight.FillColor = Color3.fromRGB(0, 255, 150)
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.Adornee = char
        highlight.Parent = container
    end

    if nameplatesActive then
        local bb = Instance.new("BillboardGui")
        bb.Size = UDim2.new(0, 120, 0, 30)
        bb.AlwaysOnTop = true
        bb.StudsOffset = Vector3.new(0, 2.5, 0)
        bb.Adornee = head
        
        local tl = Instance.new("TextLabel")
        tl.Size = UDim2.new(1, 0, 1, 0)
        tl.Text = p.DisplayName or p.Name
        tl.TextColor3 = Color3.fromRGB(255, 255, 255)
        tl.Font = Enum.Font.SourceSansBold
        tl.TextSize = 13
        tl.BackgroundTransparency = 1
        tl.Parent = bb
        bb.Parent = container
    end

    if boxesActive then
        local box = Instance.new("SelectionBox")
        box.Adornee = char
        box.Color3 = Color3.fromRGB(255, 0, 50)
        box.LineThickness = 0.05
        box.Parent = container
    end
end

local function refreshAllESP()
    clearESP()
    if not (espActive or nameplatesActive or boxesActive) then return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then task.spawn(applyESPToCharacter, p, p.Character) end
    end
end

Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function(char)
        if espActive or nameplatesActive or boxesActive then applyESPToCharacter(p, char) end
    end)
end)

