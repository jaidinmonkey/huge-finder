local function CreateTab(tabName)
    local contentPage = Instance.new("ScrollingFrame")
    contentPage.Size = UDim2.new(1, 0, 1, 0)
    contentPage.BackgroundTransparency = 1
    contentPage.BorderSizePixel = 0
    contentPage.ScrollBarThickness = 3
    contentPage.ScrollBarImageColor3 = Theme.Button
    contentPage.CanvasSize = UDim2.new(0, 0, 0, 0)
    contentPage.Visible = false
    contentPage.Parent = containerFrame
    
    local pageLayout = Instance.new("UIListLayout")
    pageLayout.Padding = UDim.new(0, 6)
    pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
    pageLayout.Parent = contentPage
    
    pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        contentPage.CanvasSize = UDim2.new(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 15)
    end)

    local tabBtn = Instance.new("TextButton")
    tabBtn.Size = UDim2.new(1, 0, 0, 32)
    tabBtn.Text = tabName
    tabBtn.BackgroundColor3 = Color3.fromRGB(0,0,0)
    tabBtn.BackgroundTransparency = 1
    tabBtn.TextColor3 = Theme.TextMuted
    tabBtn.BorderSizePixel = 0
    tabBtn.Font = Enum.Font.SourceSansSemibold
    tabBtn.TextSize = 14
    tabBtn.Parent = sidebar

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 4)
    btnCorner.Parent = tabBtn

    tabs[tabName] = contentPage
    tabButtons[tabName] = tabBtn

    tabBtn.MouseButton1Click:Connect(function()
        for name, page in pairs(tabs) do
            local isCurrent = (name == tabName)
            page.Visible = isCurrent
            TweenService:Create(tabButtons[name], TweenInfo.new(0.15), {
                BackgroundTransparency = isCurrent and 0 or 1,
                BackgroundColor3 = isCurrent and Theme.Button or Color3.fromRGB(0,0,0),
                TextColor3 = isCurrent and Theme.Accent or Theme.TextMuted
            }):Play()
            tabButtons[name].TextColor3 = isCurrent and Theme.Accent or Theme.TextMuted
        end
    end)

    if currentTab == nil then
        currentTab = tabName
        contentPage.Visible = true
        tabBtn.BackgroundTransparency = 0
        tabBtn.BackgroundColor3 = Theme.Button
        tabBtn.TextColor3 = Theme.Accent
    end

    return contentPage
end

