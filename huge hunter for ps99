        hitboxSize = tonumber(text)
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                p.Character.HumanoidRootPart.Size = Vector3.new(hitboxSize, hitboxSize, hitboxSize)
                p.Character.HumanoidRootPart.Transparency = 0.6
                p.Character.HumanoidRootPart.CanCollide = false
            end
        end
    end
end)

AddTextBox(combatTab, "Modify Expanded Hitbox Transparency...", function(text, enterPressed)
    if enterPressed and tonumber(text) then
        local trans = math.clamp(tonumber(text), 0, 1)
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                p.Character.HumanoidRootPart.Transparency = trans
            end
        end
    end
end)

