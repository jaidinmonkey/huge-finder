local function AddButton(tabObj, text, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -6, 0, 32)
    btn.Text = text
    btn.BackgroundColor3 = Theme.Button
    btn.TextColor3 = Theme.Text
    btn.Font = Enum.Font.SourceSans
    btn.TextSize = 14
    btn.BorderSizePixel = 0
    btn.Parent = tabObj
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 5)
    corner.Parent = btn
    
    btn.MouseEnter:Connect(function() TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Theme.ButtonHover}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Theme.Button}):Play() end)
    btn.MouseButton1Down:Connect(function() TweenService:Create(btn, TweenInfo.new(0.05), {TextColor3 = Theme.Accent}):Play() end)
    btn.MouseButton1Up:Connect(function() TweenService:Create(btn, TweenInfo.new(0.05), {TextColor3 = Theme.Text}):Play() end)
    
    btn.MouseButton1Click:Connect(callback)
    return btn
end

local function AddTextBox(tabObj, placeholder, callback)
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(1, -6, 0, 32)
    box.PlaceholderText = placeholder
    box.Text = ""
    box.BackgroundColor3 = Theme.TextBox
    box.TextColor3 = Theme.Text
    box.PlaceholderColor3 = Theme.TextMuted
    box.Font = Enum.Font.SourceSans
    box.TextSize = 14
    box.BorderSizePixel = 0
    box.Parent = tabObj
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 5)
    corner.Parent = box
    
    box.Focused:Connect(function() TweenService:Create(box, TweenInfo.new(0.15), {BackgroundColor3 = Theme.Button}):Play() end)
    box.FocusLost:Connect(function(enterPressed) 
        TweenService:Create(box, TweenInfo.new(0.15), {BackgroundColor3 = Theme.TextBox}):Play()
        callback(box.Text, enterPressed)
    end)
    return box
end

