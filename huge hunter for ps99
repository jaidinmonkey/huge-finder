-- ==========================================
-- UNIVERSAL DRAG LOGIC (MOBILE & PC SAFE)
-- ==========================================
local dragging = false
local dragStart = Vector2.new(0, 0)
local startPos = UDim2.new(0, 0, 0, 0)
local totalDragDistance = 0

local function setupDragListeners(hitboxElement)
    hitboxElement.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            totalDragDistance = 0
            dragStart = UserInputService:GetMouseLocation()
            startPos = mainFrame.Position
        end
    end)
end

setupDragListeners(titleBar)
setupDragListeners(reopenBtn)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local currentMousePos = UserInputService:GetMouseLocation()
        local delta = currentMousePos - dragStart
        totalDragDistance = delta.Magnitude
        
        mainFrame.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        -- Tiny delay prevents instant click activation on release
        task.defer(function()
            dragging = false
        end)
    end
end)

