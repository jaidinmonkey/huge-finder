    if root then
        waypoint = root.Position
        wpStatus.Text = string.format("Saved -> X:%d Y:%d Z:%d", math.floor(waypoint.X), math.floor(waypoint.Y), math.floor(waypoint.Z))
    end
end)

AddButton(waypointTab, "Teleport to Location Instantly", function()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and waypoint then
        root.CFrame = CFrame.new(waypoint + Vector3.new(0, 3, 0))
    end
end)

local tweenHeightOffset = 3
AddTextBox(waypointTab, "Set Waypoint Spawn Height Offset...", function(text, enterPressed)
    if enterPressed and tonumber(text) then tweenHeightOffset = tonumber(text) end
end)

AddButton(waypointTab, "Tween Glided Path to Waypoint", function()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and waypoint then
        local tweenInfo = TweenInfo.new((root.Position - waypoint).Magnitude / 50, Enum.EasingStyle.Linear)
        TweenService:Create(root, tweenInfo, {CFrame = CFrame.new(waypoint + Vector3.new(0, tweenHeightOffset, 0))}):Play()
    end
end)

AddButton(waypointTab, "Clear Saved Memory Location", function()
    waypoint = nil
    wpStatus.Text = "No Waypoint Saved"
end)


